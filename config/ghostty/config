copy-on-select = true
theme = catppuccin-frappe

keybind = global:ctrl+grave_accent=toggle_quick_terminal
# keybind = global:super+space=toggle_quick_terminal

keybind = ctrl+,=open_config
keybind = ctrl+shift+,=reload_config
keybind = ctrl+shift+i=inspector:toggle

# Needed on linux, ghostty sends too many mouse events
# see https://github.com/ghostty-org/ghostty/discussions/9966 and https://github.com/ghostty-org/ghostty/pull/8907
mouse-scroll-multiplier = 0.5
